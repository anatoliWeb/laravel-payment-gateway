# ============================================================
# Laravel SaaS Billing Platform with Payment Gateway Simulator
# Production Environment Example
# ============================================================
#
# This file is a safe template.
# Do not commit real production secrets.
# Replace all CHANGE_ME_* values during deployment.
#
# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME="Laravel Payment Gateway"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_GENERATED_KEY
APP_DEBUG=false
APP_URL=https://example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ------------------------------------------------------------
# URLs / Domains
# ------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=example.com,api.example.com
SESSION_DOMAIN=example.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=info
LOG_STRUCTURED_CONTEXT=true
LOG_QUEUE_EVENTS=true
LOG_REALTIME_EVENTS=true

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=payment_gateway
DB_USERNAME=payment_gateway
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Dedicated testing database placeholder for CI/test isolation.
DB_TEST_DATABASE=payment_gateway_testing
DB_TEST_USERNAME=payment_gateway
DB_TEST_PASSWORD=CHANGE_ME_TEST_DB_PASSWORD

MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ------------------------------------------------------------
# Queue
# ------------------------------------------------------------
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

# Worker tuning (safe defaults, tune per environment)
QUEUE_WORKER_QUEUES=webhooks,realtime,notifications,activity,emails,default,low
QUEUE_WORKER_SLEEP=1
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=90
QUEUE_WORKER_BACKOFF=10

# ------------------------------------------------------------
# Cache / Session
# ------------------------------------------------------------
CACHE_STORE=redis
SESSION_DRIVER=database

# ------------------------------------------------------------
# Mail
# ------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_MAIL_USERNAME
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# Broadcasting / Reverb
# ------------------------------------------------------------
BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001
REVERB_APP_KEY=CHANGE_ME_REVERB_APP_KEY
REVERB_APP_SECRET=CHANGE_ME_REVERB_APP_SECRET
REVERB_APP_ID=CHANGE_ME_REVERB_APP_ID
REVERB_HOST=realtime.example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_BROADCAST_HOST=reverb

# ------------------------------------------------------------
# Horizon
# ------------------------------------------------------------
HORIZON_NAME=payment-gateway-horizon
HORIZON_PATH=horizon

# ------------------------------------------------------------
# Security Notes
# ------------------------------------------------------------
SECURITY_RATE_LIMITS_ENABLED=true
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_CSP_ENABLED=true
SECURITY_CSP_REPORT_ONLY=false
SANCTUM_TOKEN_EXPIRATION=1440

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------
MONITORING_HEALTH_ENABLED=true
MONITORING_HEALTH_PROTECTED_ENABLED=true
MONITORING_HEALTH_EXPOSE_DETAILS=false

# ------------------------------------------------------------
# Frontend Runtime (if used)
# ------------------------------------------------------------
VITE_API_BASE_URL=https://example.com/api
VITE_REVERB_APP_KEY=CHANGE_ME_REVERB_APP_KEY
VITE_REVERB_HOST=realtime.example.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_FORCE_TLS=true

# ------------------------------------------------------------
# Billing / Payment Gateway (future module placeholders)
# ------------------------------------------------------------
# PAYMENT_WEBHOOK_SECRET=CHANGE_ME_PAYMENT_WEBHOOK_SECRET
# IDEMPOTENCY_TTL_MINUTES=1440
